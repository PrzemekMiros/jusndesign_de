{% include "partials/header.njk" %}

<article class="product-page pt-xlarge">
  <div class="container">
    <div class="bg-light-1 rounded-md p-3 p-md-5">
      <div class="p-md-3">

      <div class="product-main row">
        <div class="col-md-6 product-gallery" data-product-gallery>
          <a
            href="{{ productImage | url }}"
            class="lightbox-trigger product-main-link"
            data-no-swup
            data-product-main-link
            data-lightbox-src="{{ productImage | url }}"
          >
            <img src="{{ productImage }}" alt="{{ title }}" class="main-image" data-product-main-image>
          </a>
          {% if galleryImages and galleryImages.length %}
            <div class="gallery-thumbs" aria-label="Miniaturansichten der Produktbilder">
              <button
                type="button"
                class="gallery-thumb is-active"
                data-product-thumb
                data-image-src="{{ productImage | url }}"
                data-image-alt="{{ title }}"
                aria-label="Foto 1 anzeigen"
              >
                <img src="{{ productImage }}" alt="{{ title }} - 1" class="thumb-image rounded-md">
              </button>
              {% for image in galleryImages %}
                <button
                  type="button"
                  class="gallery-thumb"
                  data-product-thumb
                  data-image-src="{{ image | url }}"
                  data-image-alt="{{ title }} - {{ loop.index + 1 }}"
                  aria-label="Foto anzeigen {{ loop.index + 1 }}"
                >
                  <img src="{{ image }}" alt="{{ title }} - {{ loop.index + 1 }}" class="thumb-image rounded-md">
                </button>
              {% endfor %}
            </div>
          {% endif %}
        </div>

        <div class="col-md-6 product-info">
          {% include "partials/breadcrumbs.njk" %}

          <h1 class="h2 product-title">{{ title }}</h1>

<!--
          <div class="product-price h2">
            <span class="amount">{{ price }}</span>
            <span class="currency">PLN</span>
          </div>
-->

          <div class="product-status">
            <div class="product-short-description">
              {{ description }}
            </div>
            <p class="vin-notice">
               {{ vinNotice }}
            </p>
          </div>

          <div class="actions">
            <a href="https://ore4x4.pl/pl/428-zabudowy-jusn" target="_blank" title="Geh in den Laden" class="button-anim btn-write magnetic mt-2 fade-in" data-strength="40">
              <div class="button-anim-text">
                <span>Geh in den Laden</span>
                <span>Geh in den Laden</span>
              </div>
              <div class="button-anim-icon">
                <svg height="18" viewBox="0 0 100 100" width="18" xmlns="http://www.w3.org/2000/svg" class="icon-link" style="enable-background:new 0 0 100 100" version="1.1" x="0px" xml:space="preserve" xmlns:xlink="http://www.w3.org/1999/xlink" y="0px">
                  <g>
                    <path d="M83.3,79.7c0,2-1.6,3.6-3.6,3.6H20.3c-2,0-3.6-1.6-3.6-3.6V20.3c0-2,1.6-3.6,3.6-3.6h23.4V9.5H20.3   c-6,0-10.8,4.8-10.8,10.8v59.4c0,6,4.8,10.8,10.8,10.8h59.4c6,0,10.8-4.8,10.8-10.8V56.3h-7.2V79.7z" fill="var(--color-accent-1)"></path>
                    <polygon fill="var(--color-accent-1)" points="56.3,9.5 56.3,16.7 78.2,16.7 49.9,45 55,50.1 83.3,21.8 83.3,43.7 90.5,43.7 90.5,9.5  "></polygon>
                  </g>
                </svg>
              </div>
            </a>
            <a href="mailto:contact@jusndesigneurope.com?subject=Produktanfrage: {{ title }}" title="Fragen Sie nach dem Produkt" class="button-anim btn-write magnetic mt-2 fade-in" data-strength="40">
              <div class="button-anim-text">
                <span>Fragen Sie nach dem Produkt</span>
                <span>Fragen Sie nach dem Produkt</span>
              </div>
              <div class="button-anim-icon">
                <svg height="18" viewBox="0 0 100 100" width="18" xmlns="http://www.w3.org/2000/svg" class="icon-link" style="enable-background:new 0 0 100 100" version="1.1" x="0px" xml:space="preserve" xmlns:xlink="http://www.w3.org/1999/xlink" y="0px">
                  <g>
                    <path d="M83.3,79.7c0,2-1.6,3.6-3.6,3.6H20.3c-2,0-3.6-1.6-3.6-3.6V20.3c0-2,1.6-3.6,3.6-3.6h23.4V9.5H20.3   c-6,0-10.8,4.8-10.8,10.8v59.4c0,6,4.8,10.8,10.8,10.8h59.4c6,0,10.8-4.8,10.8-10.8V56.3h-7.2V79.7z" fill="var(--color-accent-1)"></path>
                    <polygon fill="var(--color-accent-1)" points="56.3,9.5 56.3,16.7 78.2,16.7 49.9,45 55,50.1 83.3,21.8 83.3,43.7 90.5,43.7 90.5,9.5  "></polygon>
                  </g>
                </svg>
              </div>
            </a>

          </div>

          <div class="trust-badges">
            <p>Garantiert sicher einkaufen</p>
          </div>
        </div>
      </div>

      <div class="product-details rounded-md bg-light-2 py-3 px-3 py-md-3 px-md-5 mt-5">
        <section class="details-tab">
          <h2 class="section-title">Produktdetails</h2>
          
          <div class="specs-grid bg-light-1 p-4">
            <div class="spec-item small">
              <strong>Material</strong> {{ material }}
            </div>

             <div class="spec-item small">
              <strong>Produktionsprozess</strong> {{ process }}
            </div>

            {% if capacityStatic %}
            <div class="spec-item small">
              <strong>Statische Belastbarkeit:</strong> 
              {{ capacityStatic }}
            </div>
            {% endif %}

            {% if capacityDynamic %}
            <div class="spec-item small">
              <strong>Dynamische Belastbarkeit:</strong> 
             {{ capacityDynamic }}
            </div>
            {% endif %}

            {% if weight %}
            <div class="spec-item small">
              <strong>Gewicht:</strong> {{ weight }}
            </div>
            {% endif %}
          </div>

          <div class="description-content">
            {{ content | safe }}
          </div>
        </section>

      </div>

      </div>
    </div>
  </div>
</article>

<div class="lightbox" id="lightbox" aria-hidden="true">
  <div class="lightbox-backdrop" data-lightbox-close></div>
  <div class="lightbox-content" role="dialog" aria-modal="true" aria-label="Fotoprodukt">
    <button type="button" class="lightbox-close" data-lightbox-close>X</button>
    <img src="" alt="" class="lightbox-image" id="lightbox-image">
    <div class="lightbox-nav" aria-label="Galerienavigation">
      <button type="button" class="lightbox-nav-btn" data-lightbox-prev aria-label="Vorheriges Foto">Vorherige</button>
      <button type="button" class="lightbox-nav-btn" data-lightbox-next aria-label="Nächstes Foto">Nächste</button>
    </div>
  </div>
</div>



{% include "partials/footer.njk" %}

